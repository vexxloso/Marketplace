generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  passwordHash String
  role      UserRole @default(USER)
  isVerified Boolean @default(false)
  isSuspended Boolean @default(false)
  isBanned  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  bookings  Booking[]
  reviews   Review[]
  messages  Message[]
  notifications Notification[]
  payments  Payment[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  addressLine String?
  city        String?
  state       String?
  country     String?
  latitude    Decimal?      @db.Decimal(9, 6)
  longitude   Decimal?      @db.Decimal(9, 6)
  pricePerDay Decimal       @db.Decimal(10, 2)
  weekendPrice Decimal?     @db.Decimal(10, 2)
  cleaningFee Decimal       @default(0) @db.Decimal(10, 2)
  minimumStayNights Int     @default(1)
  instantBook Boolean       @default(true)
  cancellationPolicy CancellationPolicy @default(MODERATE)
  lastMinuteDiscountPercent Int @default(0)
  weeklyDiscountPercent Int @default(0)
  status      ListingStatus @default(DRAFT)
  moderationNote String?
  hostId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  host     User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]
  images   ListingImage[]
  seasonalRates ListingSeasonalRate[]

  @@index([hostId])
  @@index([status])
  @@index([city, country])
  @@index([latitude, longitude])
}

enum UserRole {
  USER
  ADMIN
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

model ListingSeasonalRate {
  id          String   @id @default(cuid())
  listingId    String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  pricePerDay  Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([startDate, endDate])
}

model Booking {
  id        String        @id @default(cuid())
  checkIn   DateTime      @db.Date
  checkOut  DateTime      @db.Date
  totalPrice Decimal      @db.Decimal(10, 2)
  status    BookingStatus @default(PENDING)
  guestId   String
  listingId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  guest   User    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  review  Review?
  messages Message[]
  payment Payment?

  @@index([guestId])
  @@index([listingId])
  @@index([checkIn, checkOut])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Review {
  id        String  @id @default(cuid())
  rating    Int
  comment   String?
  moderationStatus ReviewModerationStatus @default(VISIBLE)
  moderationNote String?
  authorId  String
  listingId String
  bookingId String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([authorId, listingId])
  @@index([listingId])
}

enum ReviewModerationStatus {
  VISIBLE
  HIDDEN
}

model ListingImage {
  id           String   @id @default(cuid())
  listingId    String
  fileName     String   @unique
  originalName String
  mimeType     String
  createdAt    DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  readAt    DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([senderId])
  @@index([bookingId, readAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  guestId               String
  stripeCheckoutSessionId String?     @unique
  currency              String        @default("usd")
  amountTotal           Decimal       @db.Decimal(10, 2)
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guest   User    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([status])
}

model PlatformSetting {
  id                    String   @id @default(cuid())
  commissionRatePercent Decimal  @default(12) @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}
